# ===== إعدادات البوت =====
BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ

# ===== قاعدة البيانات (SQLite — منفصل عن Postgres) =====
BOT_DATABASE_URL=sqlite://library.db

# ===== وضع الاتصال =====
# webhook  → استقبال تحديثات تليجرام عبر Webhook (مناسب للإنتاج)
# polling  → اتصال مستمر Long Polling (مناسب للتطوير المحلي)
CONNECTION_MODE=polling

# ===== إعدادات Webhook (مطلوبة فقط عند CONNECTION_MODE=webhook) =====
WEBHOOK_URL=https://example.com
WEBHOOK_PATH=/webhook
PORT=8080

# ===== القناة الخاصة لتأمين الملفات =====
# أرسل ملفاً للقناة/المجموعة الخاصة واحصل على الـ chat_id منها
STORAGE_CHANNEL_ID=-1001234567890

# ===== معرّف الأدمن =====
ADMIN_ID=123456789

# ===== اسم المكتبة (يظهر في رسائل البوت) =====
LIBRARY_NAME=SBERE_books

# ===== اسم المشرف للتواصل (يظهر في رسالة المساهمة) =====
ADMIN_USERNAME=mm_0_oo

# ===== الحد الأقصى لحجم الملف بالميجابايت =====
MAX_FILE_SIZE_MB=50

# ===== عدد العناصر في كل صفحة =====
PAGE_SIZE=10
